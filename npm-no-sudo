# Install npm global packages without sudo (PEP 668 / NodeSource friendly)
# 1. mkdir -p ~/.npm-global
# 2. npm config set prefix '~/.npm-global'
# 3. Add to ~/.zshrc or ~/.profile:
#    export PATH=~/.npm-global/bin:$PATH
#
# On Ubuntu 26, prefer: npm from NodeSource + this prefix, or use pipx for Python CLIs.

mkdir -p "${HOME}/.npm-global"
npm config set prefix "${HOME}/.npm-global"

if ! grep -q 'npm-global/bin' "${HOME}/.zshrc" 2>/dev/null; then
  printf '\nexport PATH="${HOME}/.npm-global/bin:${PATH}"\n' >> "${HOME}/.zshrc"
fi

echo "Done. Restart shell or: source ~/.zshrc"
